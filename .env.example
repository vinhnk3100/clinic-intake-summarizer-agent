# Clinic Intake Summarizer — local development configuration
# Copy this file to `.env` and fill in your values.

# --- Model provider: Google AI Studio API key mode (local dev) ---
# FALSE = use Google AI Studio (API key). TRUE = use Vertex AI (needs GCP auth).
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-api-key-here

# --- Model selection (configurable, not hard-coded in code) ---
GEMINI_MODEL=gemini-2.5-flash-lite
